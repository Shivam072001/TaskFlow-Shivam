{
	"info": {
		"name": "TaskFlow API",
		"description": "Complete API collection for TaskFlow — multi-tenant task management platform.\n\nBase URL: http://localhost:8080\n\n**Quick start:**\n1. Run `Login` request (pre-filled with test@example.com / password123)\n2. The token is auto-saved to the `token` collection variable\n3. All other requests use it via `{{token}}` in the Authorization header\n\n**Variables used:**\n- `baseUrl` — API base URL\n- `token` — JWT auth token (auto-set by Login)\n- `orgID`, `workspaceID`, `projectID`, `taskID`, `teamID`, `commentID`, `fieldID`, `invitationID`, `userID` — entity UUIDs to fill in as you test",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "token", "value": "" },
		{ "key": "orgID", "value": "" },
		{ "key": "workspaceID", "value": "" },
		{ "key": "projectID", "value": "" },
		{ "key": "taskID", "value": "" },
		{ "key": "teamID", "value": "" },
		{ "key": "commentID", "value": "" },
		{ "key": "fieldID", "value": "" },
		{ "key": "invitationID", "value": "" },
		{ "key": "userID", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"auth": { "type": "noauth" },
						"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.token) {",
									"    pm.collectionVariables.set('token', res.token);",
									"    console.log('Token saved to collection variable');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"auth": { "type": "noauth" },
						"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						}
					}
				}
			]
		},
