					"request": {
						"method": "GET",
						"header": [],
						"auth": { "type": "noauth" },
						"description": "This is an informational request. To actually connect, use a WebSocket client (e.g. Postman's WebSocket tab, wscat, or browser JS):\n\n```\nws://localhost:8080/ws?token=<your-jwt-token>\n```\n\nEvents you will receive:\n- task_created — { type, payload: <task>, project_id }\n- task_updated — { type, payload: <task>, project_id }\n- task_deleted — { type, payload: { id: \"<uuid>\" } }\n- force_logout — { type, payload: { reason: \"token_expired\" } }",
						"url": {
							"raw": "{{baseUrl}}/ws?token={{token}}",
							"host": ["{{baseUrl}}"],
							"path": ["ws"],
							"query": [
