POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret
POSTGRES_DB=taskflow
DATABASE_URL=postgres://taskflow:taskflow_secret@db:5432/taskflow?sslmode=disable
JWT_SECRET=change-me-to-a-random-secret
API_PORT=8080
FRONTEND_PORT=3000
BCRYPT_COST=12

# CORS (optional — comma-separated origins, defaults to localhost:3000,5173)
# CORS_ORIGINS=https://app.example.com,http://localhost:3000

# Frontend (optional — only set when frontend and backend are on different domains)
# VITE_API_BASE_URL=https://api.example.com
# VITE_WS_BASE_URL=wss://api.example.com
